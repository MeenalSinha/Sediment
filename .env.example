# ============================================================
# SEDIMENT — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# ============================================================

# ---------- General ----------
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:4000

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql://sediment:sediment@localhost:5432/sediment
PGHOST=localhost
PGPORT=5432
PGUSER=sediment
PGPASSWORD=sediment
PGDATABASE=sediment

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Reddit OAuth (Reddit Developer Platform) ----------
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_REDIRECT_URI=http://localhost:4000/api/auth/reddit/callback
REDDIT_USER_AGENT=web:sediment:v0.1.0 (by /u/your_username)

# ---------- Session / JWT ----------
SESSION_SECRET=replace_with_a_long_random_string
JWT_SECRET=replace_with_another_long_random_string
JWT_EXPIRES_IN=7d

# ---------- AI (OpenAI GPT-5.5 or equivalent) ----------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5

# ---------- Storage (choose one) ----------
STORAGE_PROVIDER=supabase
# Supabase Storage
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=sediment-artifacts
# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Web app (Vite, must be prefixed VITE_) ----------
VITE_API_BASE_URL=http://localhost:4000
VITE_REDDIT_LOGIN_URL=http://localhost:4000/api/auth/reddit/login
VITE_SOCKET_URL=http://localhost:4000
